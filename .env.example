# PlantPal environment variables
# Copy to .env and adjust as needed:  cp .env.example .env

# ─── Ports ─────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=8501
AI_PORT=8001
REDIS_PORT=6379

# ─── Frontend → Backend connection ────────────────────────
API_URL=http://localhost:8000

# ─── Backend CORS (comma-separated origins) ───────────────
CORS_ORIGINS=http://localhost:8501,http://localhost:5173

# ─── Redis / rate limiting (EX3) ──────────────────────────
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_PER_MINUTE=60

# ─── AI advisor microservice (EX3) ────────────────────────
AI_SERVICE_URL=http://localhost:8001
# Optional — set these to use Google Gemini instead of the rule-based
# fallback.  Leave empty to stay fully local/deterministic.
GOOGLE_API_KEY=
GOOGLE_GEMINI_MODEL=

# ─── Security (EX3 / Session 11) ──────────────────────────
# Rotate JWT_SECRET every 90 days (see docs/security-checklist.md).
JWT_SECRET=change-me-in-production-please-32-bytes-min
JWT_ISSUER=plantpal-backend
JWT_AUDIENCE=plantpal-clients
JWT_EXPIRY_MINUTES=30
DEFAULT_EDITOR_USERNAME=gardener
DEFAULT_EDITOR_PASSWORD=plantpal
